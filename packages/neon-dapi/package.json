{
  "name": "@cityofzion/neon-dapi",
  "description": "Neon implementation of dApi(NEP-21)",
  "version": "5.10.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CityOfZion/neon-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "neo",
    "dapi",
    "javascript",
    "libraries"
  ],
  "author": "Raul Duarte Pereira (https://github.com/raulduartep)",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "ae": "api-extractor run --local",
    "build": "tsc -b",
    "dist": "tsc -m commonjs --outDir dist",
    "dist:prod": "tsc -m commonjs --outDir dist",
    "clean": "rimraf ./lib ./dist ./temp tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build && npm run dist:prod",
    "lint": "eslint src/**/*.ts __tests__/**/*.ts",
    "pretty": "prettier --write --loglevel=warn \"./{src,__{tests,integration}__}/**/*.ts\"",
    "start": "jest --watch",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js"
  },
  "peerDependencies": {
    "@cityofzion/neon-core": "^5.10.0"
  },
  "files": [
    "lib/",
    "dist/"
  ]
}
